<?xml version="1.0" encoding="utf-8"?>
<!--
    KumaCheck connects to user-configured Uptime Kuma servers; many users
    self-host on a LAN with no TLS termination (http://192.168.x.x:3001 or
    http://kuma.lan). Android's network security config can't match IP CIDR
    ranges via <domain> entries, so we keep cleartext permitted at
    base-config (S2: this can't be tightened without breaking IP-literal
    LAN deployments) but additionally enumerate the well-known
    private/loopback names below for readers (and lint tools) to parse the
    intent. Runtime backstop:
    [SettingsViewModel.isInsecureCleartextUrl] flips a banner whenever the
    active server URL is `http://` against a non-private host, so a
    phishing redirect to `http://attacker.com:3001` doesn't disappear
    silently.

    Trust anchors are intentionally left at platform defaults (system CAs
    only) — user-installed CAs are not trusted, so a malicious certificate
    sideloaded onto the device cannot MITM the connection.
-->
<network-security-config xmlns:tools="http://schemas.android.com/tools">
    <base-config cleartextTrafficPermitted="true"
        tools:ignore="InsecureBaseConfiguration" />

    <!-- S2: explicit allow-list for the LAN names users typically paste.
         These domain entries are advisory — base-config already permits
         cleartext globally because Android `<domain>` doesn't support
         CIDR — but they document which hosts a security-conscious
         tightening would keep, and they make `manifest merger` lint
         report the surface clearly. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="true">lan</domain>
        <domain includeSubdomains="true">local</domain>
        <domain includeSubdomains="true">internal</domain>
        <domain includeSubdomains="true">home</domain>
    </domain-config>
</network-security-config>
