    <path android:fillColor="#FFFFFF" android:pathData="M15.5,7 a2.5,2.5 0 1,0 5,0 a2.5,2.5 0 1,0 -5,0 z" />
    <!-- Head -->
    <path android:fillColor="#FFFFFF" android:pathData="M5,13 a7,7 0 1,0 14,0 a7,7 0 1,0 -14,0 z" />
